<UserControl
    x:Class="SAMCS_WPF.Views.MonitorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="1000"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="10"
            Background="#FF2D2D30">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="20"
                Foreground="Gray"
                Text="[左侧渲染区预留: robot_viewer (Web 3D)]" />
        </Border>

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <GroupBox
                Grid.Row="0"
                Padding="10"
                FontSize="14"
                Header="系统连接">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Text="串口：" />
                    <ComboBox
                        Width="80"
                        Margin="0,0,15,0"
                        ItemsSource="{Binding AvailablePorts}"
                        SelectedItem="{Binding SelectedPort}" />
                    <TextBlock
                        Margin="0,0,5,0"
                        VerticalAlignment="Center"
                        Text="波特率：" />
                    <ComboBox
                        Width="90"
                        Margin="0,0,15,0"
                        ItemsSource="{Binding BaudRates}"
                        SelectedItem="{Binding SelectedBaudRate}" />
                    <Button
                        Width="80"
                        Height="30"
                        Command="{Binding ToggleConnectionCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="连 接" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Content" Value="断 开" />
                                        <Setter Property="Foreground" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </GroupBox>

            <GroupBox
                Grid.Row="1"
                Margin="0,10,0,0"
                FontSize="13"
                Header="六轴参数监控矩阵">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Background="#F8F8F8"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1,1,0,1"
                        CornerRadius="4,0,0,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="40" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="45" />
                                <RowDefinition Height="40" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                                <RowDefinition Height="35" />
                            </Grid.RowDefinitions>

                            <Border
                                Grid.Row="0"
                                Background="#EFEFEF"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="#333333"
                                    Text="轴 / 参数" />
                            </Border>
                            <Border
                                Grid.Row="1"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#555"
                                    Text="电机型号" />
                            </Border>
                            <Border
                                Grid.Row="2"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="#007ACC"
                                    Text="当前位置" />
                            </Border>
                            <Border
                                Grid.Row="3"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    Foreground="#555"
                                    Text="设定速度" />
                            </Border>
                            <Border
                                Grid.Row="4"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="上限位" />
                            </Border>
                            <Border
                                Grid.Row="5"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="下限位" />
                            </Border>
                            <Border
                                Grid.Row="6"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="加速 (ms)" />
                            </Border>
                            <Border
                                Grid.Row="7"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="减速 (ms)" />
                            </Border>
                            <Border
                                Grid.Row="8"
                                BorderBrush="#E5E5E5"
                                BorderThickness="0,0,0,1">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="螺距 (mm)" />
                            </Border>
                            <Border Grid.Row="9">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="#666"
                                    Text="细分 (P/R)" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1,1,1,1"
                        CornerRadius="0,4,4,0">
                        <ItemsControl ItemsSource="{Binding Axes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E5E5" BorderThickness="0,0,1,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="45" />
                                                <RowDefinition Height="40" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="35" />
                                                <RowDefinition Height="35" />
                                            </Grid.RowDefinitions>

                                            <Border
                                                Grid.Row="0"
                                                Background="#EFEFEF"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        Foreground="#333333"
                                                        Text="{Binding AxisName}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Grid.Row="1"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="12"
                                                    Foreground="#007ACC"
                                                    Text="{Binding MotorModel}" />
                                            </Border>

                                            <Border
                                                Grid.Row="2"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNearLimit}" Value="True">
                                                                <Setter Property="Background" Value="#FFEBEB" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <TextBox
                                                        Width="55"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Foreground="#333333"
                                                        Text="{Binding CurrentPosition, Mode=TwoWay, StringFormat={}{0:F2}}"
                                                        TextAlignment="Center" />
                                                    <TextBlock
                                                        Margin="2,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="Gray"
                                                        Text="{Binding PosUnit}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Grid.Row="3"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <TextBox
                                                        Width="45"
                                                        VerticalAlignment="Center"
                                                        Text="{Binding Velocity, Mode=TwoWay}"
                                                        TextAlignment="Center" />
                                                    <TextBlock
                                                        Margin="2,0,0,0"
                                                        VerticalAlignment="Center"
                                                        FontSize="11"
                                                        Foreground="Gray"
                                                        Text="{Binding VelUnit}" />
                                                </StackPanel>
                                            </Border>

                                            <Border
                                                Grid.Row="4"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBox
                                                    Width="50"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding SoftLimitMax, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                            <Border
                                                Grid.Row="5"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBox
                                                    Width="50"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding SoftLimitMin, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                            <Border
                                                Grid.Row="6"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBox
                                                    Width="45"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Acceleration, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                            <Border
                                                Grid.Row="7"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBox
                                                    Width="45"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Deceleration, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                            <Border
                                                Grid.Row="8"
                                                BorderBrush="#E5E5E5"
                                                BorderThickness="0,0,0,1">
                                                <TextBox
                                                    Width="45"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Pitch, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                            <Border Grid.Row="9">
                                                <TextBox
                                                    Width="55"
                                                    Margin="0,2"
                                                    VerticalAlignment="Center"
                                                    Text="{Binding Division, Mode=TwoWay}"
                                                    TextAlignment="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>
            </GroupBox>

            <GroupBox
                Grid.Row="2"
                Margin="0,10,0,0"
                Padding="10"
                FontSize="14"
                Header="操作">
                <UniformGrid
                    Width="450"
                    HorizontalAlignment="Center"
                    Columns="3">
                    <Button
                        Height="40"
                        Margin="5"
                        Command="{Binding HomeAllAxesCommand}"
                        Content="回到默认位置" />
                    <Button
                        Height="40"
                        Margin="5"
                        Command="{Binding TestAllAxesCommand}"
                        Content="往返运动测试" />
                    <Button
                        Height="40"
                        Margin="5"
                        Background="#FFFF4B4B"
                        BorderThickness="0"
                        Command="{Binding EmergencyStopCommand}"
                        Content="紧急停止"
                        FontWeight="Bold"
                        Foreground="White" />
                </UniformGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
