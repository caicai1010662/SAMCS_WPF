<UserControl
    x:Class="SAMCS_WPF.Views.MonitorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    d:DesignHeight="750"
    d:DesignWidth="1100"
    Background="#F5F5F7"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  卡片样式：白底圆角微弱阴影  -->
        <Style x:Key="MaterialCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="15"
                        Direction="270"
                        Opacity="0.04"
                        ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <!--  卡片标题  -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!--  普通按钮：灰白圆角 + 悬停变色 + 按下变深  -->
        <Style x:Key="MaterialButton" TargetType="Button">
            <Setter Property="Background" Value="#E8E8ED" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D1D1D6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C7C7CC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  主按钮：强调蓝  -->
        <Style
            x:Key="PrimaryButton"
            BasedOn="{StaticResource MaterialButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#0071E3" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0060C0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  危险按钮：警示红 · 悬停深红 + 按下更暗  -->
        <Style
            x:Key="DangerButton"
            BasedOn="{StaticResource MaterialButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#FF3B30" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E53020" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC2210" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>

        <!--  Web3D 渲染区：仅布局占位，视觉效果由 index.html 内部控制  -->
        <Border Grid.Column="0" Margin="0,0,15,0">
            <wv2:WebView2 x:Name="WebView3D" DefaultBackgroundColor="Transparent" />
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  系统连接卡片  -->
            <Border
                Grid.Row="0"
                Padding="20"
                Style="{StaticResource MaterialCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="系统连接" />
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="#86868B"
                            Text="通讯串口：" />
                        <ComboBox
                            Width="120"
                            Height="32"
                            Margin="0,0,15,0"
                            Padding="5,0"
                            VerticalContentAlignment="Center"
                            ItemsSource="{Binding AvailablePorts}"
                            SelectedItem="{Binding SelectedPort}" />
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="#86868B"
                            Text="波特率：" />
                        <ComboBox
                            Width="80"
                            Height="32"
                            Margin="0,0,15,0"
                            Padding="5,0"
                            VerticalContentAlignment="Center"
                            ItemsSource="{Binding BaudRates}"
                            SelectedItem="{Binding SelectedBaudRate}" />
                        <Button
                            Width="100"
                            Height="32"
                            Command="{Binding ToggleConnectionCommand}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource PrimaryButton}" TargetType="Button">
                                    <Setter Property="Content" Value="连 接 设 备" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Content" Value="断 开 连 接" />
                                            <Setter Property="Background" Value="#FF3B30" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!--
                ===== 六轴参数监控表格 =====
                设计原则：去网格线、动静分区、交替行底色。
                上半区（位置+速度）为重点监视区，有彩色底色。
                下半区（限位+配置）为辅助参数区，交替白/浅灰。
            -->
            <Border
                Grid.Row="1"
                Margin="0,15,0,0"
                Padding="20"
                Style="{StaticResource MaterialCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource CardTitle}"
                        Text="参数监控" />

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  ========== 左侧标签列 ==========  -->
                        <Border
                            Grid.Column="0"
                            Background="#F8F8FA"
                            BorderBrush="#E8E8EC"
                            BorderThickness="1,1,0,1"
                            CornerRadius="6,0,0,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1.1*" />
                                    <!--  Row 0: 轴名称表头  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 1: 轴号  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 2: 电机型号  -->
                                    <RowDefinition Height="1.6*" />
                                    <!--  Row 3: 绝对位置  -->
                                    <RowDefinition Height="1.4*" />
                                    <!--  Row 4: 速度  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 5: 位置限位  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 6: 速度限位  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 7: 加速系数  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 8: 减速系数  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 9: 螺距  -->
                                    <RowDefinition Height="1*" />
                                    <!--  Row 10: 细分  -->
                                </Grid.RowDefinitions>

                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                        <Setter Property="VerticalAlignment" Value="Center" />
                                        <Setter Property="Foreground" Value="#8E8E93" />
                                        <Setter Property="FontSize" Value="13" />
                                    </Style>
                                </Grid.Resources>

                                <TextBlock
                                    Grid.Row="0"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Foreground="#1D1D1F"
                                    Text="监控参数" />

                                <TextBlock Grid.Row="1" FontWeight="SemiBold" Text="轴号" />
                                <TextBlock Grid.Row="2" FontWeight="SemiBold" Text="电机型号" />

                                <!--  动态监视区  -->
                                <Border Grid.Row="3" Background="#EBF5FF">
                                    <TextBlock FontWeight="Bold" Foreground="#007AFF" Text="绝对位置 (mm/°)" />
                                </Border>
                                <Border Grid.Row="4" Background="#F2F2F7">
                                    <TextBlock FontWeight="Bold" Foreground="#1D1D1F" Text="速度 (mm/°·s)" />
                                </Border>

                                <!--  静态配置区  -->
                                <TextBlock Grid.Row="5" Text="位置限位" />
                                <TextBlock Grid.Row="6" Text="速度限位" />
                                <Border Grid.Row="7" Background="#F8F8FA">
                                    <TextBlock Text="加速系数 (ms)" />
                                </Border>
                                <TextBlock Grid.Row="8" Text="减速系数 (ms)" />
                                <Border Grid.Row="9" Background="#F8F8FA">
                                    <TextBlock Text="螺距 (mm)" />
                                </Border>
                                <TextBlock Grid.Row="10" Text="细分 (P/R)" />
                            </Grid>
                        </Border>

                        <!--  ========== 右侧数据列 ==========  -->
                        <Border
                            Grid.Column="1"
                            BorderBrush="#E8E8EC"
                            BorderThickness="1,1,1,1"
                            CornerRadius="0,6,6,0">
                            <ItemsControl ItemsSource="{Binding Axes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="1.1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1.6*" />
                                                <RowDefinition Height="1.4*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="1*" />
                                            </Grid.RowDefinitions>

                                            <!--  Row 0：轴名 + 状态灯  -->
                                            <Border Grid.Row="0" Background="#F8F8FA">
                                                <StackPanel
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        Margin="0,0,6,0"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Text="●">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#34C759" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Foreground" Value="#FF3B30" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="Bold"
                                                        Foreground="#1D1D1F"
                                                        Text="{Binding AxisName}" />
                                                </StackPanel>
                                            </Border>

                                            <!--  Row 1：轴号  -->
                                            <Border Grid.Row="1">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="#8E8E93"
                                                    Text="{Binding AxisId}" />
                                            </Border>

                                            <!--  Row 2：电机型号  -->
                                            <Border Grid.Row="2">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="#6E6E73"
                                                    Text="{Binding MotorModel}" />
                                            </Border>

                                            <!--  Row 3：绝对位置（重点监视·大号加粗）  -->
                                            <Border Grid.Row="3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#EBF5FF" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNearLimit}" Value="True">
                                                                <Setter Property="Background" Value="#FFF0F0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="24"
                                                    FontWeight="Bold"
                                                    Foreground="#007AFF"
                                                    Text="{Binding CurrentPosition, StringFormat={}{0:F3}}" />
                                            </Border>

                                            <!--  Row 4：速度（重点监视·加粗）  -->
                                            <Border Grid.Row="4" Background="#F2F2F7">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="#1D1D1F"
                                                    Text="{Binding Velocity, StringFormat={}{0:F3}}" />
                                            </Border>

                                            <!--  Row 5~10：静态配置（交替底色·统一加粗）  -->
                                            <Border Grid.Row="5">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#3A3A3C"
                                                    Text="{Binding LimitDisplay, Mode=OneWay}" />
                                            </Border>
                                            <Border Grid.Row="6" Background="#F8F8FA">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#3A3A3C"
                                                    Text="{Binding VelocityLimitDisplay, Mode=OneWay}" />
                                            </Border>
                                            <Border Grid.Row="7">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#6E6E73"
                                                    Text="{Binding Acceleration}" />
                                            </Border>
                                            <Border Grid.Row="8" Background="#F8F8FA">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#6E6E73"
                                                    Text="{Binding Deceleration}" />
                                            </Border>
                                            <Border Grid.Row="9">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#6E6E73"
                                                    Text="{Binding Pitch}" />
                                            </Border>
                                            <Border Grid.Row="10" Background="#F8F8FA">
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="Bold"
                                                    Foreground="#6E6E73"
                                                    Text="{Binding Division}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!--  设备控制卡片  -->
            <Border
                Grid.Row="2"
                Margin="0,15,0,0"
                Padding="20"
                Style="{StaticResource MaterialCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardTitle}" Text="设备控制" />
                    <UniformGrid
                        Width="500"
                        HorizontalAlignment="Center"
                        Columns="3">
                        <Button
                            Height="45"
                            Margin="8"
                            Command="{Binding HomeAllAxesCommand}"
                            Content="复位原点"
                            Style="{StaticResource MaterialButton}">
                            <Button.ToolTip>
                                <TextBlock Width="200" TextWrapping="Wrap">
                                    控制六轴同时返回默认工作位置。<LineBreak />
                                    <LineBreak />
                                    当前所有轴将以同步方式启动，
                                    并自动运动至预设归位坐标。</TextBlock>
                            </Button.ToolTip>
                        </Button>

                        <Button
                            Height="45"
                            Margin="8"
                            Command="{Binding TestAllAxesCommand}"
                            Content="往返运动测试"
                            Style="{StaticResource MaterialButton}">
                            <Button.ToolTip>
                                <TextBlock Width="200" TextWrapping="Wrap">
                                    执行六轴限位往返测试。<LineBreak />
                                    <LineBreak />
                                    各轴将依次执行：<LineBreak />
                                    上限位 → 下限位 → 默认位置</TextBlock>
                            </Button.ToolTip>
                        </Button>

                        <Button
                            Height="45"
                            Margin="8"
                            Command="{Binding EmergencyStopCommand}"
                            Content="紧 急 停 止"
                            Style="{StaticResource DangerButton}">
                            <Button.ToolTip>
                                <TextBlock Width="200" TextWrapping="Wrap">
                                    立即向全部轴发送停止指令。<LineBreak />
                                    <LineBreak />
                                    执行后：<LineBreak />
                                    所有正在运动的轴将尝试立即停止。</TextBlock>
                            </Button.ToolTip>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
