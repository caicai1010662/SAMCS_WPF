<Window
    x:Class="SAMCS_WPF.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:SAMCS_WPF.Views"
    xmlns:vm="clr-namespace:SAMCS_WPF.ViewModels"
    Title=" S A M C S"
    Width="1600"
    Height="900"
    Background="#F3F3F3">

    <!--
        三个子 View 不再通过 DataTemplate + ContentControl 动态创建/销毁。
        改为全部在启动时创建，通过 Visibility 做显示/隐藏切换。
        这样 MonitorView 的 WebView2 只初始化一次，
        Three.js Scene 只创建一次，URDF/STL 只加载一次。
        切换界面不重新加载，模型始终驻留内存。
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--
            ===== 导航标签样式 =====
            干净白底 + 圆角标签 + 选中底部蓝色刻度线。
            默认灰字透明底 → 悬停浅灰底 → 选中蓝字淡蓝底 + 底部蓝线。
        -->
        <Style x:Key="NavTabStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#8E8E93" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="tabBorder"
                            Padding="24,10,24,10"
                            Background="Transparent"
                            CornerRadius="8"
                            Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="3" />
                                </Grid.RowDefinitions>

                                <ContentPresenter
                                    Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextBlock.FontSize="{TemplateBinding FontSize}"
                                    TextBlock.Foreground="{TemplateBinding Foreground}" />

                                <!--  底部刻度线：默认透明，选中时蓝色  -->
                                <Border
                                    x:Name="underline"
                                    Grid.Row="1"
                                    Width="16"
                                    Height="3"
                                    Margin="0,4,0,0"
                                    HorizontalAlignment="Center"
                                    Background="#007AFF"
                                    CornerRadius="2"
                                    Opacity="0" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!--  悬停：浅灰底  -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="tabBorder" Property="Background" Value="#F2F2F7" />
                            </MultiTrigger>

                            <!--  选中：淡蓝底 + 蓝字 + 底部蓝色刻度线  -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tabBorder" Property="Background" Value="#EBF5FF" />
                                <Setter Property="Foreground" Value="#007AFF" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="underline" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="6*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ===== 导航栏：白底 + 底部分隔线  =====  -->
        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="White"
            BorderBrush="#E5E5EA"
            BorderThickness="0,0,0,1">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <RadioButton
                    Margin="8,0,8,0"
                    Content="状态监控"
                    IsChecked="{Binding IsMonitorSelected}"
                    Style="{StaticResource NavTabStyle}" />
                <RadioButton
                    Margin="8,0,8,0"
                    Content="脑立体定向"
                    IsChecked="{Binding IsStereotaxicSelected}"
                    Style="{StaticResource NavTabStyle}" />
                <RadioButton
                    Margin="8,0,8,0"
                    Content="微电极植入"
                    IsChecked="{Binding IsImplantSelected}"
                    Style="{StaticResource NavTabStyle}" />
            </StackPanel>
        </Border>

        <!--
            三个页面 View 共享同一个 Grid 格子（Row 1），叠加在一起。
            同一时刻只有一个 Visible，其余 Collapsed。
            所有 View 在启动时创建一次，之后只做 Visibility 切换，不做销毁/重建。
        -->
        <!--
            Visibility 绑定说明：
            View 自身的 DataContext 已被设为子 ViewModel（如 MonitorVM），
            但 IsMonitorSelected 在 MainViewModel 上。
            所以 Visibility 绑定需要用 RelativeSource 往上一层找 Window 的 DataContext。
            等价白话文："问我爸爸（Window）的 DataContext（MainViewModel）要 IsMonitorSelected"。
        -->
        <views:MonitorView
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="10,10,10,10"
            DataContext="{Binding MonitorVM}"
            Visibility="{Binding DataContext.IsMonitorSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
        <views:StereotaxicView
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="10,10,10,10"
            DataContext="{Binding StereotaxicVM}"
            Visibility="{Binding DataContext.IsStereotaxicSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
        <views:ImplantView
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="10,10,10,10"
            DataContext="{Binding ImplantVM}"
            Visibility="{Binding DataContext.IsImplantSelected, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Window>
