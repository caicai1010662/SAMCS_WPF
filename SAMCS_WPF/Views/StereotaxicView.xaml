<!--
    StereotaxicView - 脑立体定向页面。
    
    布局：
    左侧 40%：WebView2 加载 3D 小鼠颅骨模型（SkullViewer.html + MouseSkull.glb）
    右侧 60%：功能面板
    - 上 70%：三个模块（轴运动控制、五点记录、当前方位）
    - 下 30%：设备日志输出窗口
    - 底部：全局急停按钮
-->
<UserControl
    x:Class="SAMCS_WPF.Views.StereotaxicView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    d:DesignHeight="1080"
    d:DesignWidth="1920"
    Background="#F5F5F7"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  卡片样式  -->
        <Style x:Key="MaterialCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                        BlurRadius="15"
                        Direction="270"
                        Opacity="0.04"
                        ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>

        <!--  卡片标题  -->
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <!--  普通按钮  -->
        <Style x:Key="MaterialButton" TargetType="Button">
            <Setter Property="Background" Value="#E8E8ED" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D1D1D6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C7C7CC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Jog 正转按钮（蓝底白字）  -->
        <Style x:Key="JogPlusButton" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#0088FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0066CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005BB5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#004A9E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Jog 反转按钮（深灰底白字）  -->
        <Style x:Key="JogMinusButton" TargetType="Button">
            <Setter Property="Width" Value="100" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Background" Value="#3A3A3C" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2C2C2E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A4D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2C2C2E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  停止按钮（数值调用，橙底白字）  -->
        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="#FF9500" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#CC7700" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="border"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E68600" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CC7700" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  主按钮  -->
        <Style
            x:Key="PrimaryButton"
            BasedOn="{StaticResource MaterialButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#0071E3" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0060C0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  急停按钮  -->
        <Style
            x:Key="EmergencyStopButton"
            BasedOn="{StaticResource MaterialButton}"
            TargetType="Button">
            <Setter Property="Background" Value="#CC0000" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Height" Value="44" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF1A1A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  模式切换按钮  -->
        <Style x:Key="ModeToggleButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="border"
                            Padding="8,4,8,4"
                            Background="#F2F2F7"
                            BorderBrush="#E5E5EA"
                            BorderThickness="1"
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0071E3" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#0071E3" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0071E3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  速度选择按钮  -->
        <Style x:Key="SpeedButton" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border
                            x:Name="border"
                            Padding="8,4,8,4"
                            Background="#F2F2F7"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0071E3" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#0071E3" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0071E3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  轴运动控制：轴行卡片  -->
        <Style x:Key="AxisRowBorder" TargetType="Border">
            <Setter Property="Padding" Value="8,5,8,5" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="#FAFAFC" />
            <Setter Property="BorderBrush" Value="#E8E8EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!--  五点记录：步骤行卡片  -->
        <Style x:Key="FivePointStepBorder" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="#FAFAFC" />
            <Setter Property="BorderBrush" Value="#E8E8EC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!--  五点记录：步骤标签文字  -->
        <Style x:Key="FivePointStepLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="428*" />
            <ColumnDefinition Width="323*" />
            <ColumnDefinition Width="319*" />
        </Grid.ColumnDefinitions>

        <!--  左侧：3D 颅骨模型渲染区  -->
        <Border Grid.Column="0" Margin="0,0,15,0">
            <wv2:WebView2 x:Name="WebViewSkull" DefaultBackgroundColor="Transparent" />
        </Border>

        <!--  右侧：功能面板  -->
        <Grid Grid.Column="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="7*" />
                <RowDefinition Height="3*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  ===================== 上行：三个功能模块 =====================  -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3.8*" />
                    <ColumnDefinition Width="3.8*" />
                    <ColumnDefinition Width="2.4*" />
                </Grid.ColumnDefinitions>

                <!--  ===== 上左：轴运动控制 =====  -->
                <Border
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    Padding="10"
                    Style="{StaticResource MaterialCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                        </Grid.RowDefinitions>

                        <!--  标题行：标题 + 模式切换同行  -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#1D1D1F"
                                Text="六轴运动控制" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <RadioButton
                                    x:Name="ModeCoarse"
                                    Command="{Binding SwitchModeCommand}"
                                    CommandParameter="Coarse"
                                    Content="粗调"
                                    GroupName="ControlMode"
                                    IsChecked="True"
                                    Style="{StaticResource ModeToggleButton}" />
                                <RadioButton
                                    x:Name="ModeFine"
                                    Command="{Binding SwitchModeCommand}"
                                    CommandParameter="Fine"
                                    Content="细调"
                                    GroupName="ControlMode"
                                    Style="{StaticResource ModeToggleButton}" />
                                <RadioButton
                                    x:Name="ModeNumeric"
                                    Command="{Binding SwitchModeCommand}"
                                    CommandParameter="Numeric"
                                    Content="数值调"
                                    GroupName="ControlMode"
                                    Style="{StaticResource ModeToggleButton}" />
                            </StackPanel>
                        </Grid>

                        <!--  速度选择 + 数值调子模式  -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,4">
                            <!--  粗调速度行（粗调/数值调下可见）  -->
                            <StackPanel
                                Margin="0,0,0,3"
                                Orientation="Horizontal"
                                Visibility="{Binding ShowCoarseSpeeds, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="#1D1D1F"
                                    Text="{Binding SpeedLabel}" />
                                <ListBox
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemsSource="{Binding CoarseSpeeds}"
                                    SelectedItem="{Binding SelectedCoarseSpeed}"
                                    SelectionMode="Single">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <RadioButton
                                                            Content="{Binding}"
                                                            ContentStringFormat="F3"
                                                            GroupName="SpeedGroup"
                                                            IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                                            Style="{StaticResource SpeedButton}" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>

                            <!--  细调速度行（细调/数值调模式下可见）  -->
                            <StackPanel
                                Margin="0,0,0,3"
                                Orientation="Horizontal"
                                Visibility="{Binding ShowFineSpeeds, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="#1D1D1F"
                                    Text="{Binding FineSpeedLabel}" />
                                <ListBox
                                    Background="Transparent"
                                    BorderThickness="0"
                                    ItemsSource="{Binding FineSpeeds}"
                                    SelectedItem="{Binding SelectedFineSpeed}"
                                    SelectionMode="Single">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <RadioButton
                                                            Content="{Binding}"
                                                            ContentStringFormat="F3"
                                                            GroupName="SpeedGroup"
                                                            IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                                            Style="{StaticResource SpeedButton}" />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>

                            <!--  数值调子模式（仅数值调下可见）  -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsNumericMode, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="#1D1D1F"
                                    Text="模式:" />
                                <RadioButton
                                    Command="{Binding SwitchNumericModeCommand}"
                                    CommandParameter="Absolute"
                                    Content="绝对"
                                    GroupName="NumericMode"
                                    IsChecked="True"
                                    Style="{StaticResource SpeedButton}" />
                                <RadioButton
                                    Command="{Binding SwitchNumericModeCommand}"
                                    CommandParameter="Relative"
                                    Content="相对"
                                    GroupName="NumericMode"
                                    Style="{StaticResource SpeedButton}" />
                            </StackPanel>
                        </StackPanel>

                        <!--  六轴列表 —— 按功能分三组  -->
                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" />
                                <RowDefinition Height="3*" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>

                            <!--  ====== 组 1: 角度轴 R / P ======  -->
                            <Border
                                Grid.Row="0"
                                Margin="0,0,0,9"
                                Padding="6,4"
                                Background="#F8F8FA"
                                BorderBrush="#D1D1D6"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid Grid.IsSharedSizeScope="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        Grid.Row="0"
                                        Margin="4,0,0,4"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="#8E8E93"
                                        Text="角度轴  R / P" />

                                    <!--  Axis 0: R(旋转)  -->
                                    <Border
                                        Grid.Row="1"
                                        Margin="0,0,0,2"
                                        Style="{StaticResource AxisRowBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Name" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Gap1" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Position" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Unit" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Status" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Controls" />
                                            </Grid.ColumnDefinitions>

                                            <!--  轴名  -->
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="#1D1D1F"
                                                Text="{Binding Axes[0].AxisName}" />

                                            <!--  间距  -->
                                            <Border Grid.Column="1" Width="6" />

                                            <!--  当前位置（核心信息，大字醒目）  -->
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                FontFamily="Consolas"
                                                FontSize="20"
                                                FontWeight="Bold"
                                                Foreground="#007AFF"
                                                Text="{Binding Axes[0].CurrentPosition, StringFormat={}{0:F3}}" />

                                            <!--  单位（已移除）  -->

                                            <!--  状态灯  -->
                                            <Ellipse
                                                Grid.Column="4"
                                                Width="12"
                                                Height="12"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Stroke" Value="#1D1D1F" />
                                                        <Setter Property="StrokeThickness" Value="1" />
                                                        <Setter Property="Fill" Value="#34C759" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Axes[0].IsRunning}" Value="True">
                                                                <Setter Property="Fill" Value="#FF3B30" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!--  Jog 按钮区  -->
                                            <StackPanel
                                                Grid.Column="6"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Visibility="{Binding IsJogMode, Converter={StaticResource BoolToVis}}">
                                                <Button
                                                    x:Name="JogRMinus"
                                                    Content="-"
                                                    MouseLeave="JogButton_MouseLeave"
                                                    PreviewMouseLeftButtonDown="JogButton_MouseDown"
                                                    PreviewMouseLeftButtonUp="JogButton_MouseUp"
                                                    Style="{StaticResource JogMinusButton}"
                                                    Tag="0-" />
                                                <Border
                                                    Width="1"
                                                    Margin="20,0,20,0"
                                                    VerticalAlignment="Stretch"
                                                    Background="#000000" />
                                                <Button
                                                    x:Name="JogRPlus"
                                                    Content="+"
                                                    MouseLeave="JogButton_MouseLeave"
                                                    PreviewMouseLeftButtonDown="JogButton_MouseDown"
                                                    PreviewMouseLeftButtonUp="JogButton_MouseUp"
                                                    Style="{StaticResource JogPlusButton}"
                                                    Tag="0+" />
                                            </StackPanel>

                                            <!--  数值调区  -->
                                            <StackPanel
                                                Grid.Column="6"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Visibility="{Binding IsNumericMode, Converter={StaticResource BoolToVis}}">
                                                <TextBox
                                                    Width="80"
                                                    Height="34"
                                                    VerticalContentAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    PreviewTextInput="NumericInput_PreviewTextInput"
                                                    Tag="0"
                                                    Text="{Binding Axes[0].InputText, UpdateSourceTrigger=PropertyChanged}"
                                                    TextChanged="NumericInput_TextChanged">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="BorderBrush" Value="#E5E5EA" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Axes[0].IsInputValid}" Value="False">
                                                                    <Setter Property="BorderBrush" Value="#FF3B30" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <Button
                                                    Width="54"
                                                    Height="34"
                                                    Margin="3,0,0,0"
                                                    Padding="4,0"
                                                    Command="{Binding ExecuteNumericMoveCommand}"
                                                    CommandParameter="0"
                                                    Content="执行"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Style="{StaticResource PrimaryButton}" />
                                                <Button
                                                    Margin="3,0,0,0"
                                                    Padding="4,0"
                                                    Command="{Binding StopAxisCommand}"
                                                    CommandParameter="0"
                                                    Content="停止"
                                                    Style="{StaticResource StopButton}" />
                                                <!--  错误提示已移至设备日志  -->
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!--  Axis 1: P(俯仰)  -->
                                    <Border
                                        Grid.Row="2"
                                        Margin="0,0,0,2"
