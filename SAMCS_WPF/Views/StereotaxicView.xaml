                <!--  上中：五点记录  -->
                <Border
                    Grid.Column="1"
                    Margin="5,0,5,0"
                    Padding="10"
                    Style="{StaticResource MaterialCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="#1D1D1F"
                                Text="五点记录" />
                            <!--  调平状态指示  -->
                            <Border
                                Grid.Column="1"
                                Padding="12,3"
                                HorizontalAlignment="Right"
                                CornerRadius="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FFF0F0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSkullLeveled}" Value="True">
                                                <Setter Property="Background" Value="#E5F9EA" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="13" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未调平" />
                                            <Setter Property="Foreground" Value="#FF3B30" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSkullLeveled}" Value="True">
                                                    <Setter Property="Text" Value="已调平" />
                                                    <Setter Property="Foreground" Value="#34C759" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel Grid.IsSharedSizeScope="True">
                                    <!--  ====== 初定位 ======  -->
                                    <Border
                                        Margin="0,0,0,5"
                                        Padding="6,3"
                                        Background="#EBF5FF"
                                        CornerRadius="4"
                                        HorizontalAlignment="Stretch">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="#0071E3"
                                            Text="初定位" />
                                    </Border>

                                    <!--  步骤 1: 设置前囟点  -->
                                    <Border Style="{StaticResource FivePointStepBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="FivePLabel" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="115" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Style="{StaticResource FivePointStepLabel}"
                                                Text="1. 设置前囟点" />
                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Grid.ColumnSpan="3"
                                                        Height="34" Padding="10,5"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding SetBregmaCommand}" Content="设置"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource PrimaryButton}" />
                                                <Button Grid.Column="4" Width="70"
                                                        Height="34" Padding="10,5"
                                                        Command="{Binding DeleteBregmaCommand}" Content="删除"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource MaterialButton}" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#34C759"
                                                Text="✓">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBregmaSet}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="1"
                                                                                Duration="0:0:0.3" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!--  步骤 2: 设置后囟点  -->
                                    <Border Style="{StaticResource FivePointStepBorder}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FivePLabel" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="115" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Style="{StaticResource FivePointStepLabel}"
                                                    Text="2. 设置后囟点" />
                                                <Grid Grid.Column="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="70" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Grid.ColumnSpan="3"
                                                            Height="34" Padding="10,5"
                                                            HorizontalAlignment="Stretch"
                                                            Command="{Binding SetLambdaCommand}" Content="设置"
                                                            FontSize="13" FontWeight="SemiBold"
                                                            Style="{StaticResource PrimaryButton}" />
                                                    <Button Grid.Column="4" Width="70"
                                                            Height="34" Padding="10,5"
                                                            Command="{Binding DeleteLambdaCommand}" Content="删除"
                                                            FontSize="13" FontWeight="SemiBold"
                                                            Style="{StaticResource MaterialButton}" />
                                                </Grid>
                                                <TextBlock
                                                    Grid.Column="3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="#34C759"
                                                    Text="✓">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsLambdaSet}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation
                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                    To="1"
                                                                                    Duration="0:0:0.3" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation
                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                    To="0"
                                                                                    Duration="0:0:0.1" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="#6E6E73"
                                                Text="{Binding BregmaLambdaDvInfo}" />
                                        </StackPanel>
                                    </Border>

                                    <!--  步骤 3: 前后囟中点  -->
                                    <Border Style="{StaticResource FivePointStepBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="FivePLabel" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="115" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Style="{StaticResource FivePointStepLabel}"
                                                Text="3. 前后囟中点" />
                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding MoveToMidpointCommand}" Content="移动至"
                                                        FontSize="13" FontWeight="SemiBold">
                                                    <Button.Style>
                                                        <Style BasedOn="{StaticResource MaterialButton}" TargetType="Button">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanMoveToMidpoint}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Grid.Column="2" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding SetMidpointCommand}" Content="设置"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource PrimaryButton}" />
                                                <Button Grid.Column="4" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding DeleteMidpointCommand}" Content="删除"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource MaterialButton}" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#34C759"
                                                Text="✓">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMidpointSet}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="1"
                                                                                Duration="0:0:0.3" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!--  步骤 4: 左位点  -->
                                    <Border Style="{StaticResource FivePointStepBorder}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="FivePLabel" />
                                                <ColumnDefinition Width="16" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="115" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Style="{StaticResource FivePointStepLabel}"
                                                Text="4. 左位点" />
                                            <Grid Grid.Column="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding MoveToMidLeftCommand}" Content="移动至"
                                                        FontSize="13" FontWeight="SemiBold">
                                                    <Button.Style>
                                                        <Style BasedOn="{StaticResource MaterialButton}" TargetType="Button">
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanMoveToMidLeft}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Grid.Column="2" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding SetMidLeftCommand}" Content="设置"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource PrimaryButton}" />
                                                <Button Grid.Column="4" Width="70" Height="34" Padding="10,5"
                                                        Command="{Binding DeleteMidLeftCommand}" Content="删除"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        Style="{StaticResource MaterialButton}" />
                                            </Grid>
                                            <TextBlock
                                                Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#34C759"
                                                Text="✓">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMidLeftSet}" Value="True">
                                                                <DataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="1"
                                                                                Duration="0:0:0.3" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.EnterActions>
                                                                <DataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </DataTrigger.ExitActions>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!--  步骤 5: 右位点  -->
                                    <Border Style="{StaticResource FivePointStepBorder}">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="FivePLabel" />
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="115" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock
                                                    Grid.Column="0"
                                                    Style="{StaticResource FivePointStepLabel}"
                                                    Text="5. 右位点" />
                                                <Grid Grid.Column="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="70" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Width="70" Height="34" Padding="10,5"
                                                            Command="{Binding MoveToMidRightCommand}" Content="移动至"
                                                            FontSize="13" FontWeight="SemiBold">
                                                        <Button.Style>
                                                            <Style BasedOn="{StaticResource MaterialButton}" TargetType="Button">
                                                                <Setter Property="IsEnabled" Value="False" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CanMoveToMidRight}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="True" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                    <Button Grid.Column="2" Width="70" Height="34" Padding="10,5"
                                                            Command="{Binding SetMidRightCommand}" Content="设置"
                                                            FontSize="13" FontWeight="SemiBold"
                                                            Style="{StaticResource PrimaryButton}" />
                                                    <Button Grid.Column="4" Width="70" Height="34" Padding="10,5"
                                                            Command="{Binding DeleteMidRightCommand}" Content="删除"
                                                            FontSize="13" FontWeight="SemiBold"
                                                            Style="{StaticResource MaterialButton}" />
                                                </Grid>
                                                <TextBlock
                                                    Grid.Column="3"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    FontSize="18"
                                                    FontWeight="Bold"
                                                    Foreground="#34C759"
                                                    Text="✓">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Opacity" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMidRightSet}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation
                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                    To="1"
                                                                                    Duration="0:0:0.3" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation
                                                                                    Storyboard.TargetProperty="Opacity"
                                                                                    To="0"
                                                                                    Duration="0:0:0.1" />
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="#6E6E73"
                                                Text="{Binding MidLeftRightDvInfo}" />
                                        </StackPanel>
                                    </Border>

                                    <!--  "查看配准" 按钮 —— 在初定位流程完成后可查看  -->
                                    <Button
                                        Height="36"
                                        Margin="0,4,0,0"
                                        Padding="12,0"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding OpenRegistrationCommand}"
                                        Content="查看配准"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource PrimaryButton}" />

                                </StackPanel>
                            </ScrollViewer>

                            <!--  ====== 重定位 ======  -->
                            <StackPanel Grid.Row="1">
                                <Border
                                    Margin="0,5,0,5"
                                    Padding="6,3"
                                    Background="#EBF5FF"
                                    CornerRadius="4"
                                    HorizontalAlignment="Stretch">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Foreground="#0071E3"
                                        Text="重定位" />
                                </Border>

                                <Border
                                    Padding="12,10"
                                    Background="#FAFAFC"
                                    BorderBrush="#E8E8EC"
                                    BorderThickness="1"
                                    CornerRadius="5"
                                    HorizontalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Height="36"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding RelocateCommand}"
                                            Content="重定位"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Style="{StaticResource PrimaryButton}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!--  上右：当前方位  -->
                <Border
                    Grid.Column="2"
                    Margin="5,0,0,0"
                    Padding="15"
                    Style="{StaticResource MaterialCard}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardTitle}" Text="当前方位" />
                        <TextBlock
                            FontSize="14"
                            Foreground="#86868B"
                            Text="AP / ML / DV / Rot / Pitch（待实现）"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  ===================== 下行：设备日志 =====================  -->
            <Border
                Grid.Row="1"
                Padding="15"
                Style="{StaticResource MaterialCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource CardTitle}"
                        Text="设备日志" />
                    <TextBox
                        x:Name="LogTextBox"
                        Grid.Row="1"
                        AcceptsReturn="True"
                        Background="#1A1A2E"
                        BorderBrush="#2D2D44"
                        BorderThickness="1"
                        CaretBrush="#00FF88"
                        FontFamily="Consolas"
                        FontSize="12"
                        Foreground="#CCCCCC"
                        IsReadOnly="True"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Text="{Binding LogText, Mode=OneWay}"
                        TextChanged="LogTextBox_TextChanged"
                        TextWrapping="Wrap" />
                </Grid>
            </Border>

            <!--  ===================== 底部：全局急停 =====================  -->
            <Border Grid.Row="2" Padding="0,8,0,0">
                <Button
                    Command="{Binding EmergencyStopCommand}"
                    Content="全 局 急 停"
                    Style="{StaticResource EmergencyStopButton}" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
