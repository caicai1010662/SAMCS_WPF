<!--
    RegistrationWindow - 颅骨配准窗口。
    独立于主窗口三 Tab 页，以独立 Window 展示五点采集结果与坐标系配准数据。
-->
<Window
    x:Class="SAMCS_WPF.Views.RegistrationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="颅骨配准"
    Width="520"
    Height="580"
    Background="#F5F5F7"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DataGridHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8E8E93" />
            <Setter Property="Padding" Value="4,6" />
        </Style>

        <Style x:Key="DataGridCell" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Foreground" Value="#1D1D1F" />
            <Setter Property="Padding" Value="4,4" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  ====== 标题 + 调平状态 ======  -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                FontSize="18"
                FontWeight="Bold"
                Foreground="#1D1D1F"
                Text="颅骨配准" />
            <Border
                Grid.Column="2"
                Padding="12,4"
                CornerRadius="6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FFF0F0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSkullLeveled}" Value="True">
                                <Setter Property="Background" Value="#E5F9EA" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="14" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="未调平" />
                            <Setter Property="Foreground" Value="#FF3B30" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSkullLeveled}" Value="True">
                                    <Setter Property="Text" Value="已调平" />
                                    <Setter Property="Foreground" Value="#34C759" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>

        <!--  ====== DV 校验信息 ======  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,12"
            Padding="12,10"
            Background="White"
            BorderBrush="#E8E8EC"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="校验结果" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource DataGridHeader}"
                        Text="前后囟 DV" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding BregmaLambdaDvInfo}" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Style="{StaticResource DataGridHeader}"
                        Text="左右位点 DV" />
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidLeftRightDvInfo}" />

                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Style="{StaticResource DataGridHeader}"
                        Text="Bregma→Lambda 距离" />
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding BregmaLambdaDistance}" />
                </Grid>
            </StackPanel>
        </Border>

        <!--  ====== 五点坐标表 ======  -->
        <Border
            Grid.Row="2"
            Margin="0,0,0,12"
            Padding="12,10"
            Background="White"
            BorderBrush="#E8E8EC"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionTitle}" Text="五点坐标 (AP / ML / DV, 单位: mm)" />

                <!--  表头  -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource DataGridHeader}"
                        Text="标记点" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridHeader}"
                        Text="AP" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridHeader}"
                        Text="ML" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridHeader}"
                        Text="DV" />
                </Grid>

                <!--  分割线  -->
                <Border
                    Height="1"
                    Margin="0,0,0,4"
                    Background="#E8E8EC" />

                <!--  Bregma  -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontWeight="SemiBold"
                        Style="{StaticResource DataGridCell}"
                        Text="Bregma" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding BregmaAp}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding BregmaMl}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding BregmaDv}" />
                </Grid>

                <!--  Lambda  -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontWeight="SemiBold"
                        Style="{StaticResource DataGridCell}"
                        Text="Lambda" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding LambdaAp}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding LambdaMl}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding LambdaDv}" />
                </Grid>

                <!--  Midpoint  -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontWeight="SemiBold"
                        Style="{StaticResource DataGridCell}"
                        Text="Midpoint" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidpointAp}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidpointMl}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidpointDv}" />
                </Grid>

                <!--  MidLeft  -->
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontWeight="SemiBold"
                        Style="{StaticResource DataGridCell}"
                        Text="MidLeft" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidLeftAp}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidLeftMl}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidLeftDv}" />
                </Grid>

                <!--  MidRight  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        FontWeight="SemiBold"
                        Style="{StaticResource DataGridCell}"
                        Text="MidRight" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidRightAp}" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidRightMl}" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{StaticResource DataGridCell}"
                        Text="{Binding MidRightDv}" />
                </Grid>
            </StackPanel>
        </Border>

        <!--  ====== 底部按钮 ======  -->
        <Border Grid.Row="4" VerticalAlignment="Bottom">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="140"
                    Height="36"
                    Click="CloseButton_Click"
                    Content="关闭"
                    FontSize="14"
                    FontWeight="SemiBold"
                    IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
